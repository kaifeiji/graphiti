# Copy this file to graphiti/.env and replace the placeholder values.
# This project assumes your ArcGIS-hosted LLM service exposes an OpenAI-compatible API.

GRAPHITI_HOST=0.0.0.0
GRAPHITI_PORT=8010
GRAPHITI_GROUP_ID=graphiti
GRAPHITI_SEARCH_LIMIT=6
GRAPHITI_CHUNK_SIZE=1400
GRAPHITI_MAX_HISTORY_MESSAGES=8
GRAPHITI_MAX_COMPLETION_TOKENS=1200
GRAPHITI_TELEMETRY_ENABLED=false

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-your-neo4j-password
NEO4J_DATABASE=neo4j

ARCGIS_MODEL_HOST=aimodelsdev.arcgis.com
ARCGIS_TIMEOUT_SECONDS=60.0
ARCGIS_ACCESS_TOKEN=replace-with-your-arcgis-token
ARCGIS_CHAT_MODEL=gpt-5.2
ARCGIS_SMALL_CHAT_MODEL=gpt-4.1-mini
ARCGIS_EMBEDDING_MODEL=text-embedding-3-small
